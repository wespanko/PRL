# Copy this file to `.env` and fill in real values.
# `.env` MUST be gitignored — never commit secrets.

# Anthropic API key for the Assistant chat feature.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-key-here

# Sentry DSN for backend error reporting. Optional in dev; set on Render in prod.
# Free dev tier at https://sentry.io covers 5k errors/month.
SENTRY_DSN=

# Optional: tag Sentry events with an environment. Defaults to "production".
SENTRY_ENVIRONMENT=production
