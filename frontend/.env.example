# Frontend env. Vercel reads this convention; copy to .env.local for local
# overrides. .env.local is gitignored.
#
# In production, set this to your Render backend URL (e.g.
#   https://panko-backend.onrender.com
# ). For local dev, leave empty — Vite's proxy in vite.config.js routes
# /api/* to http://127.0.0.1:8000.
VITE_API_URL=

# Sentry DSN — leave empty in dev. Set in Vercel to capture frontend errors.
# Get one at https://sentry.io (free dev tier covers 5k errors/month).
VITE_SENTRY_DSN=
